# Configuración de CompartiendoMomentos.ar

# MongoDB
# Ejemplo local: mongodb://localhost:27017/
# Ejemplo MongoDB Atlas: mongodb+srv://usuario:password@cluster.mongodb.net/
MONGODB_URI=mongodb://localhost:27017/

# MercadoPago
# Obtener tus credenciales de: https://www.mercadopago.com.ar/developers/panel
# Para TEST usa las credenciales de prueba
MERCADO_PAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Flask
SECRET_KEY=compartiendomomentos2024secreto
FLASK_ENV=production

# Puerto (para Render.com)
PORT=5000
